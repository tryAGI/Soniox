<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <NoWarn>$(NoWarn);MEAI001;CS1591</NoWarn>
  </PropertyGroup>

  <PropertyGroup Label="Nuget">
    <Description>Generated C# SDK for Soniox — real-time and async speech-to-text with 60+ language support, translation, speaker diarization, and language identification.</Description>
    <PackageTags>soniox;speech-to-text;stt;transcription;translation;realtime;websocket;meai;api;sdk;dotnet;openapi;generated</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.AI.Abstractions" Version="10.5.0" />
  </ItemGroup>

</Project>
